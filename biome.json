{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"files": {
		"includes": [
			"src/**",
			"scripts/**",
			"tests/**",
			"!tests/e2e/.last-run.json"
		]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["**/*.svelte"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"style": {
						"useConst": "off"
					}
				}
			},
			"assist": {
				"actions": {
					"source": {
						"organizeImports": "off"
					}
				}
			}
		},
		{
			"includes": ["src/app.css"],
			"linter": {
				"rules": {
					"complexity": {
						"noImportantStyles": "off"
					},
					"style": {
						"noDescendingSpecificity": "off"
					}
				}
			}
		}
	]
}
